<mvc:View
    controllerName="notes.controller.Detail"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:uxap="sap.uxap"
    xmlns:layout="sap.ui.layout"
>
    <uxap:ObjectPageLayout id="ObjectPage">
        <!-- HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:heading>
                    <Title
                        text="{title}"
                        level="H2"
                    />
                </uxap:heading>

                <uxap:expandedContent>
                    <Text text="{description}" />
                </uxap:expandedContent>

                <!-- HEADER ACTION BUTTONS -->
                <uxap:actions>
                    <Button
                        text="Edit"
                        type="Emphasized"
                        press=".onEdit"
                        enabled="{= !${view>/editMode} }"
                    />

                    <Button
                        text="Save"
                        type="Emphasized"
                        press=".onSave"
                        enabled="{view>/editMode}"
                    />

                    <Button
                        text="Cancel"
                        press=".onCancel"
                        enabled="{view>/editMode}"
                    />

                    <Button
                        text="Delete all Tasks"
                        press=".onDeleteAllTasks"
                    />

                    <Button
                        text="Send Notification"
                        press=".onCheckDueTasks"
                    />
                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- SECTIONS -->
        <uxap:sections>
            <!-- GENERAL INFORMATION TAB -->
            <uxap:ObjectPageSection title="{i18n>GeneralInfo}">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <layout:Grid class="sapUiMediumMargin">
                            <!-- TITLE -->
                            <VBox>
                                <Label text="Title" />
                                <!-- DISPLAY -->
                                <Text
                                    text="{title}"
                                    visible="{= !${view>/editMode} }"
                                />
                                <!-- EDIT -->
                                <Input
                                    value="{title}"
                                    visible="{view>/editMode}"
                                />
                            </VBox>

                            <!-- DESCRIPTION -->
                            <VBox>
                                <Label text="Description" />
                                <!-- DISPLAY -->
                                <Text
                                    text="{description}"
                                    visible="{= !${view>/editMode} }"
                                />
                                <!-- EDIT -->
                                <TextArea
                                    value="{description}"
                                    rows="1"
                                    visible="{view>/editMode}"
                                    valueLiveUpdate="true"
                                />
                            </VBox>
                        </layout:Grid>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- TASKS TAB -->
            <uxap:ObjectPageSection title="{i18n>TasksTableTitle}">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <Table
                            id="TasksTable"
                            items="{ path: 'tasks', parameters: { expand: 'status' } }"
                            class="sapUiResponsiveMargin"
                            width="auto"
                        >
                            <!-- TABLE TOOLBAR -->
                            <headerToolbar>
                                <Toolbar>
                                    <ToolbarSpacer />
                                    <Button
                                        text="Create"
                                        type="Emphasized"
                                        press=".onAddTask"
                                        enabled="{view>/editMode}"
                                    />

                                    <SearchField
                                        width="250px"
                                        search=".onFilterTasks"
                                    />
                                </Toolbar>
                            </headerToolbar>

                            <!-- TABLE COLUMNS -->
                            <columns>
                                <Column width="25%">
                                    <Text text="{i18n>columnDescription}" />
                                </Column>
                                <Column width="25%">
                                    <Text text="{i18n>columnStatus}" />
                                </Column>
                                <Column width="25%" />
                                <Column width="25%">
                                    <Text text="{i18n>columnDueDate}" />
                                </Column>

                                <Column width="25%">
                                    <Text text="{i18n>columnAssignedTo}" />
                                </Column>
                            </columns>

                            <!-- TABLE DATA -->
                            <ColumnListItem
                                highlight="{= ${status/code} === 'N' ? 'Indication05' :
                                             ${status/code} === 'I' ? 'Indication03' :
                                             'Indication04'}"
                            >
                                <cells>
                                    <Input
                                        value="{description}"
                                        editable="{view>/editMode}"
                                    />
                                    <Select
                                        selectedKey="{status_code}"
                                        items="{ path: '/Status' }"
                                        editable="{view>/editMode}"
                                        showSecondaryValues="true"
                                        change=".onStatusChange"
                                    >
                                        <core:ListItem
                                            key="{code}"
                                            text="{descr}"
                                        />
                                    </Select>
                                    <ObjectStatus
                                        id="statusObject"
                                        icon="{= ${status/code} === 'N' ? 'sap-icon://information' :
                                             ${status/code} === 'I' ? 'sap-icon://alert' :
                                             'sap-icon://sys-enter-2'}"
                                        state="{= ${status/code} === 'N' ? 'Information' :
                                             ${status/code} === 'I' ? 'Warning' :
                                             'Success'}"
                                    />

                                    <DatePicker
                                        value="{
                                            path: 'duedate',
                                            type: 'sap.ui.model.type.Date',
                                            formatOptions: {
                                                pattern: 'yyyy-MM-dd'
                                            }
                                        }"
                                        editable="{view>/editMode}"
                                    />
                                    <Input
                                        value="{assignedto}"
                                        editable="{view>/editMode}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </Table>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
